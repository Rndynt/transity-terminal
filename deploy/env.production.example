# Template env untuk GCP VM
# Salin ke /opt/transity-api/.env dan isi nilainya
# JANGAN commit file .env yang sudah diisi ke git

# ── Wajib ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=                        # min 32 chars: openssl rand -hex 32
TERMINAL_SERVICE_KEY=              # key untuk Console / OTA API access

# ── Autentikasi Realmio ────────────────────────
REALMIO_BASE_URL=https://your-tenant.realmio.com
REALMIO_TENANT_ID=your-tenant-id

# ── Frontend origin (untuk CORS) ───────────────
APP_CORS_ORIGINS=https://terminal.yourdomain.pages.dev,https://terminal.yourdomain.com

# ── Operator config ────────────────────────────
OPERATOR_SLUG=your-operator-slug
OPERATOR_TZ=Asia/Jakarta

# ── Port (Nginx proxy ke sini) ─────────────────
PORT=5000
SERVE_STATIC=false
NODE_ENV=production

# ── Redis (opsional — untuk multi-instance WS/rate-limit) ──
# REDIS_URL=redis://localhost:6379

# ── Console webhook (opsional) ─────────────────
# CONSOLE_URL=https://console.yourdomain.com
# CONSOLE_OPERATOR_SLUG=your-operator-slug
# CONSOLE_WEBHOOK_SECRET=

# ── Payment webhook ────────────────────────────
# PAYMENT_WEBHOOK_SECRET=

# ── Hold TTL ───────────────────────────────────
HOLD_TTL_SHORT_SECONDS=60
HOLD_TTL_LONG_SECONDS=1200
PENDING_BOOKING_AUTO_RELEASE=true
WEB_HOLD_TTL_MINUTES=15
OTA_HOLD_TTL_MINUTES=30
APP_HOLD_TTL_MINUTES=15

# ── Observability (opsional) ───────────────────
# SENTRY_DSN=
