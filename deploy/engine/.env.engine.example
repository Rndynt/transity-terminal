# ─────────────────────────────────────────────
# Reservation Engine — append to operator's .env
# ─────────────────────────────────────────────
# Variable names match exactly what the engine binary reads. Do not rename.

# === Feature flag ============================================================
# false → TT uses its built-in Node atomic-hold service (legacy path).
# true  → TT routes hold/release/confirm/cancel-seats through the engine.
# Either way, the engine container can run idle — flipping the flag does NOT
# require redeploying the engine.
RESERVATION_ENGINE_ENABLED=false

# === Shared HMAC secret (used by BOTH TT and engine) =========================
# Generate ONCE per operator: openssl rand -hex 32
RESERVATION_ENGINE_HMAC_SECRET=replace-with-32-byte-hex-secret

# Allowed clock skew between TT and engine signatures (seconds).
HMAC_SKEW_SECS=30

# === Engine container image ==================================================
# Image registry+name and tag. Pin a semver tag in production, never `latest`.
ENGINE_IMAGE=ghcr.io/rndynt/transity-engine
ENGINE_IMAGE_TAG=v1.0.0

# === Engine internals (sane defaults — change only if you must) ==============
ENGINE_LOG_LEVEL=info
REAPER_INTERVAL_SECS=60
DB_MIN_CONN=2
DB_MAX_CONN=10
IDEMPOTENCY_MAX=10000

# Optional: separate DB URL for the engine. Defaults to TT's DATABASE_URL.
# ENGINE_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Optional: Redis pub/sub URL. Leave empty to disable event publication.
# REDIS_URL=redis://redis:6379/0
