# ============================================================
#  TransityTerminal — Operator Environment Template
#  Copy this file to `.env` and isi sesuai operator.
#  Jangan commit file `.env` ke git.
# ============================================================

# === Operator Identity (digunakan oleh docker-compose) ===
# Slug operator (lowercase, no spaces) — dipakai untuk container & subdomain
OPERATOR_SLUG=nusa
# Port host yang dipublish (di-bind ke 127.0.0.1 lewat nginx)
HOST_PORT=5000

# === DATABASE ===
# Postgres connection string (Neon, RDS, atau Postgres lokal)
DATABASE_URL=postgresql://user:password@localhost:5432/terminal_db

# === SERVER ===
NODE_ENV=production
PORT=5000
# Timezone operator untuk perhitungan grace-period jadwal & cutoff
# Default: Asia/Jakarta. Contoh lain: Asia/Makassar, Asia/Jayapura.
OPERATOR_TZ=Asia/Jakarta

# === AUTH (Realmio) ===
# URL instance Realmio yang digunakan
REALMIO_BASE_URL=https://transity.realmio.web.id
# Tenant ID yang didaftarkan di Realmio untuk operator ini
REALMIO_TENANT_ID=nama-operator-shuttle
# Secret untuk signing JWT mobile app (B2C). WAJIB di production.
# Generate dengan: openssl rand -hex 32
JWT_SECRET=

# === Public API / Service-to-Service ===
# Service key yang dipakai TransityConsole / OTA pihak ketiga
# untuk memanggil /api/app/* dan /api/console/*
# Generate dengan: openssl rand -hex 32
TERMINAL_SERVICE_KEY=
# Secret HMAC-SHA256 untuk webhook payment gateway → /api/app/payments/webhook
PAYMENT_WEBHOOK_SECRET=
# CORS origins untuk endpoint /api/app/*. Pisah dengan koma. "*" = bebas.
APP_CORS_ORIGINS=*
# CORS origins untuk WebSocket (Socket.io). Pisah dengan koma.
# Kosong di production = block semua kecuali same-origin.
CORS_ORIGINS=

# === TransityConsole Integration (push schedule sync) ===
# URL TransityConsole. Jika kosong, push webhook di-skip (no-op).
CONSOLE_URL=http://transity-console:8080
# Slug operator di Console (umumnya sama dengan OPERATOR_SLUG)
CONSOLE_OPERATOR_SLUG=nusa
# Secret HMAC-SHA256 yang sama persis dengan setting di Console
CONSOLE_WEBHOOK_SECRET=
# Interval push snapshot rutin (ms). Default 600000 = 10 menit.
CONSOLE_SNAPSHOT_INTERVAL_MS=600000
# Jumlah hari ke depan yang dipush ke Console. Default 7.
CONSOLE_SNAPSHOT_DAYS_AHEAD=7
# Maksimum trip per snapshot HTTP (guard 413). Default 1000.
CONSOLE_SNAPSHOT_MAX_TRIPS=1000
# Trip yang sudah berangkat lebih dari N menit lalu di-skip dari snapshot.
# Default 60 menit.
SCHEDULE_SNAPSHOT_GRACE_MINUTES=60

# === Redis (OPSIONAL — wajib untuk multi-instance deploy) ===
# Native Redis URL (TCP, BUKAN REST endpoint). Contoh provider:
#   - Upstash: dashboard → tab Connect → ioredis/Node → "rediss://default:PASSWORD@HOST:6379"
#   - Aiven, Redis Cloud, atau Redis self-hosted.
# Format wajib: redis://[user:pass@]host:port  ATAU  rediss://... (TLS)
# Kalau kosong/invalid, app fallback ke in-memory (single-instance only):
#   - Socket.io broadcast hanya nyampai ke client di instance yg sama (mungkin desync antar outlet).
#   - Rate limit di-hitung per-instance (limit efektif jadi N × max).
# Untuk single-instance deploy, biarkan kosong → tidak ada masalah.
REDIS_URL=

# === Hold TTL (per sales channel, dalam menit) ===
# OTA/WEB user butuh waktu lebih untuk pilih metode pembayaran.
OTA_HOLD_TTL_MINUTES=20
WEB_HOLD_TTL_MINUTES=20
APP_HOLD_TTL_MINUTES=15

# === Hold TTL (CSO terminal, dalam detik) ===
# Hold pendek (preview seat) dan hold panjang (proses bayar).
HOLD_TTL_SHORT_SECONDS=300
HOLD_TTL_LONG_SECONDS=1800
# Set false untuk menonaktifkan auto-cancel pending booking yang expired.
PENDING_BOOKING_AUTO_RELEASE=true

# === Reservation Engine (sidecar — opsional, untuk operator high-volume) ===
# Aktifkan untuk merutekan hold/release/cancel-seats ke engine Rust sidecar.
# Default: false (TT pakai AtomicHoldService bawaan + scheduler reaper lokal).
# Dokumentasi lengkap: engine/docs/TT_HOLDS_ADAPTER_INSTRUCTIONS.md
# Saat true, SELURUH inventory write (hold, release, confirm, cancel-seats,
# reschedule) dirutekan ke engine sidecar. Reaper hold lokal otomatis mati.
RESERVATION_ENGINE_ENABLED=false
# URL engine sidecar di docker network. Default cocok dengan compose overlay.
RESERVATION_ENGINE_URL=http://engine:8000
# Shared HMAC secret. WAJIB sama persis dengan setting di engine.
# Generate dengan: openssl rand -hex 32
RESERVATION_ENGINE_HMAC_SECRET=

# === DEV ONLY ===
# Aktifkan untuk development tanpa Realmio (JANGAN di production!)
# DEV_BYPASS_AUTH=true
