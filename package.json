{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && node esbuild.config.js",
    "build:api": "node esbuild.config.js --bundle",
    "deploy:zip": "node esbuild.config.js --bundle && node deploy/make-zip.js",
    "start": "NODE_ENV=production node dist/index.js",
    "start:dev": "NODE_ENV=production DEV_BYPASS_AUTH=true node dist/index.js",
    "check": "tsc",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:fix-price-rule-scope": "tsx scripts/fix-price-rule-scope-enum.ts",
    "lint:server": "eslint server --ext .ts",
    "deadcode:server": "knip",
    "unused-exports:server": "ts-prune --project tsconfig.json | grep '^server/'"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
