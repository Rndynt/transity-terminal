    "fastify": "^5.8.2",
    "husky": "^9.1.7",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.453.0",
    "nanoid": "^3.3.11",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
