    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@replit/vite-plugin-cartographer": "^0.3.2",
    "@replit/vite-plugin-dev-banner": "^0.1.2",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
