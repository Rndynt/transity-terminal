{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "TransityTerminal — Production Dashboard",
  "uid": "transity-terminal-prod",
  "tags": ["transity", "production"],
  "timezone": "Asia/Jakarta",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "1. Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(transity_http_requests_total[1m])) by (status_class)",
          "legendFormat": "{{status_class}}xx",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "2. p50/p95/p99 Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(transity_http_request_duration_ms_bucket[1m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(transity_http_request_duration_ms_bucket[1m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(transity_http_request_duration_ms_bucket[1m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 3,
      "title": "3. Booking Funnel (hold → pay → confirmed)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(transity_booking_total{stage=\"hold\"}[5m]))", "legendFormat": "hold", "refId": "A" },
        { "expr": "sum(rate(transity_booking_total{stage=\"pay_init\"}[5m]))", "legendFormat": "pay_init", "refId": "B" },
        { "expr": "sum(rate(transity_booking_total{stage=\"confirmed\"}[5m]))", "legendFormat": "confirmed", "refId": "C" }
      ]
    },
    {
      "id": 4,
      "title": "4. Compensation Queue Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "transity_compensation_queue_size{status=\"pending\"}", "legendFormat": "pending", "refId": "A" },
        { "expr": "transity_compensation_queue_size{status=\"dead_lettered\"}", "legendFormat": "DLQ", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "5. Engine Roundtrip (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(transity_engine_request_duration_ms_bucket[1m])) by (le, op))", "legendFormat": "p95 {{op}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "6. WebSocket Connected Clients",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "transity_ws_connected_clients", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "7. DB Pool (active / idle)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "transity_db_pool_active", "legendFormat": "active", "refId": "A" },
        { "expr": "transity_db_pool_idle", "legendFormat": "idle", "refId": "B" },
        { "expr": "transity_db_pool_waiting", "legendFormat": "waiting", "refId": "C" }
      ]
    },
    {
      "id": 8,
      "title": "8. Refund Rate (per 5m, by status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "sum(rate(transity_refund_total[5m])) by (status)", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "title": "9. Webhook Idempotent Replay Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "sum(rate(transity_webhook_total[5m])) by (kind)", "legendFormat": "{{kind}}", "refId": "A" }
      ],
      "description": "kind=processed | replay_idempotent | hmac_fail"
    },
    {
      "id": 10,
      "title": "10. Health Subsystem Status (last)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        { "expr": "transity_health_subsystem_ok{subsystem=\"db\"}", "legendFormat": "db", "refId": "A" },
        { "expr": "transity_health_subsystem_ok{subsystem=\"engine\"}", "legendFormat": "engine", "refId": "B" },
        { "expr": "transity_health_subsystem_ok{subsystem=\"redis\"}", "legendFormat": "redis", "refId": "C" },
        { "expr": "transity_health_subsystem_ok{subsystem=\"realmio\"}", "legendFormat": "realmio", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ]
        }
      }
    }
  ]
}
